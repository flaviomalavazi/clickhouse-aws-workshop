# terraform.tfvars.example
# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
#
# AWS auth via the usual AWS_PROFILE / AWS_ACCESS_KEY_ID etc.

name_prefix       = "ch-aws-workshop"
aws_region        = "us-east-1"
clickhouse_region = "us-east-1"

# --- ClickHouse Cloud API auth (see providers.tf) ---
# Create the API key in the Cloud console: Organization -> API keys.
clickhouse_organization_id = "<org-uuid>"   # CLICKHOUSE_ORG_ID
clickhouse_token_key       = "<key-id>"     # CLICKHOUSE_CLOUD_API_KEY
clickhouse_token_secret    = "<key-secret>" # CLICKHOUSE_CLOUD_API_SECRET

# --- Secrets (do NOT commit the real terraform.tfvars) ---
clickhouse_password      = "change-me-strong-password"
aurora_master_password   = "change-me-strong-password"
clickpipes_user_password = "change-me-strong-password"

# --- Aurora public ingress (seeding only) ---
# ClickPipes connects privately over PrivateLink, so it does NOT need to be
# listed here. Only add your own /32 so the seed scripts can reach Aurora's
# public endpoint.
clickpipes_ingress_cidrs = [
  # "203.0.113.10/32",   # your laptop IP (for seeding)
]

# --- Pipe toggles ---
# All default to true so a SINGLE `terraform apply` brings up everything: the
# generator EC2 self-seeds Aurora (publication + clickpipes_user + rows), Terraform
# waits for that to finish, creates the `raw` database, then creates both pipes.
# (Requires the AWS CLI + curl on the machine running apply.)
#
# Prefer the old manual two-phase flow (seed yourself, then create pipes)? Set
# enable_generator_ec2 = false and both pipe toggles = false for the first apply,
# seed Aurora, then set the pipe toggles = true and apply again.
enable_postgres_clickpipe = true
enable_kinesis_clickpipe  = true
enable_generator_ec2      = true
# repo_url defaults to the canonical workshop repo; override for your own fork.
# repo_url                  = "https://github.com/<org>/clickhouse-aws-workshop"
generator_cdc_sleep       = 0.1
generator_kinesis_rate    = 1000
