# Copy to .env and fill in (after `terraform apply`, use `terraform output`).
# .env is gitignored.

# --- Aurora PostgreSQL (run_migrations.py / seed_rds.py / simulate_cdc.py) ---
# Use the public writer endpoint (terraform output aurora_writer_endpoint).
PGHOST=replace-with-aurora_writer_endpoint
PGPORT=5432
PGDATABASE=appdb
PGUSER=postgres
PGPASSWORD=change-me-strong-password

# Password run_migrations.py assigns to the clickpipes_user role.
# Must match var.clickpipes_user_password in terraform.tfvars.
CLICKPIPES_USER_PASSWORD=change-me-strong-password

# TLS to Aurora's public endpoint. Default verify-full validates the server cert
# (CA + hostname) against sql/aurora/global-bundle.pem. Set PGSSLMODE=require to
# encrypt without verifying, or PGSSLROOTCERT to point at a different CA bundle.
# PGSSLMODE=verify-full
# PGSSLROOTCERT=

# Generator volumes for the initial seed
SEED_CUSTOMERS=500
SEED_ORDERS=2000

# --- Amazon Kinesis (kinesis_producer.py) ---
AWS_REGION=us-east-1
KINESIS_STREAM_NAME=ch-aws-workshop-events
# boto3 also needs AWS credentials: set AWS_PROFILE or AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY in your shell.
